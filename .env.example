# ─────────────────────────────────────────────────────────────
# Stix Magic – environment variable template
# Copy to .env and fill in your values.
# NEVER commit a populated .env file to version control.
# ─────────────────────────────────────────────────────────────

# Required ────────────────────────────────────────────────────

# Telegram bot token obtained from @BotFather.
# The value may be the raw token OR the full BotFather message –
# the app extracts the token automatically.
TELEGRAM_BOT_TOKEN=

# Secret key used to authenticate calls to the REST API.
# Use a long random string (e.g. openssl rand -hex 32).
STIXMAGIC_API_KEY=

# Optional ────────────────────────────────────────────────────

# TCP port for the Flask web server. Defaults to 5000.
PORT=5000

# Restrict CORS to a specific origin in production.
# Default is "*" (open) which is fine for local development.
CORS_ALLOW_ORIGIN=https://stixmagic.com

# Full HTTPS URL of the Telegram Mini App page.
# If set, a "Open the Portal" Web App button is shown in the bot menu.
MINIAPP_URL=https://your-replit-domain.repl.co/miniapp

# Replit-specific: comma-separated list of public domain names.
# Set automatically by Replit; used to derive MINIAPP_URL when
# MINIAPP_URL is not explicitly provided.
REPLIT_DOMAINS=

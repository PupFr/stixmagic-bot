# ── Required ─────────────────────────────────────────────────
# Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# API key for the REST API (keep secret — used in X-API-Key header)
STIXMAGIC_API_KEY=your_api_key_here

# ── Optional ──────────────────────────────────────────────────
# Flask session secret (auto-generated if not set)
SESSION_SECRET=your_session_secret_here

# Web server port (default: 5000)
PORT=5000

# Telegram Mini App URL (auto-resolved from REPLIT_DOMAINS if not set)
MINIAPP_URL=https://your-domain.com/miniapp
